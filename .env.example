# Polymarket AI Agent Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# LLM Provider API Keys
# Add the keys for the providers you want to use
# ============================================================================

# Anthropic (for Claude models)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (for GPT models)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google (for Gemini models)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Optional: Web Search APIs
# These provide higher quality search results with better rate limits
# The agent will fall back to free search if these are not configured
# ============================================================================

# Serper.dev - Google search API
# Get your key at: https://serper.dev/
# SERPER_API_KEY=your_serper_api_key_here

# NewsAPI - For news-specific queries
# Get your key at: https://newsapi.org/
# NEWS_API_KEY=your_newsapi_key_here
